{
  "name": "itchy-native",
  "version": "2.7.11",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:prod": "eas build --platform android --profile production --local --non-interactive --output=./.prod_outputs/app-prod.aab",
    "build:ios:prod": "eas build --platform ios --profile production --local --non-interactive --output=./.prod_outputs/app-ios-prod.ipa",
    "build:ios:dev": "eas build --platform ios --profile development --local --output=./.prod_outputs/app-ios-dev.ipa",
    "build:android:local": "cd android && ./gradlew assembleRelease",
    "postinstall": "patch-package",
    "version": "node ./utils/postVersion.js"
  },
  "dependencies": {
    "@bottom-tabs/react-navigation": "^0.12.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@preeternal/react-native-cookie-manager": "^6.3.1",
    "@react-native-firebase/app": "^23.5.0",
    "@react-native-firebase/crashlytics": "^23.5.0",
    "@shopify/flash-list": "2.0.2",
    "@swan-io/react-native-browser": "^0.4.1",
    "@types/timeago": "^1.6.3",
    "approximate-number": "^2.1.1",
    "babel-preset-expo": "~55.0.8",
    "country-emoji": "^1.5.6",
    "expo": "^55.0.9",
    "expo-asset": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.19",
    "expo-file-system": "~55.0.12",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-gradle-jvmargs": "^1.1.0",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-navigation-bar": "~55.0.9",
    "expo-network": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-sharing": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.11",
    "html-entities": "^2.6.0",
    "itchy-multiplay": "^0.2.0",
    "node-html-parser": "^7.0.1",
    "prop-types": "^15.8.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-bottom-tabs": "^0.12.2",
    "react-native-device-info": "^14.0.4",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^3.3.1",
    "react-native-picker-select": "^9.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-redash": "^18.1.3",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "~4.23.0",
    "react-native-shake": "^6.8.3",
    "react-native-webrtc": "^124.0.5",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "swr": "^2.3.6",
    "time-ago": "^0.2.1",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "~19.2.10",
    "baseline-browser-mapping": "^2.10.12",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "reanimated": {
    "staticFeatureFlags": {
      "DISABLE_COMMIT_PAUSING_MECHANISM": true
    }
  }
}
